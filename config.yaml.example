# QobuzProxy Configuration
# Copy to config.yaml and fill in your details

qobuz:
  email: "user@example.com"
  password: "password"          # Or use QOBUZ_PASSWORD env var
  max_quality: auto             # auto, 5=MP3, 6=CD, 7=Hi-Res 96k, 27=Hi-Res 192k

device:
  name: "QobuzProxy"            # Name shown in Qobuz app
  uuid: null                    # Auto-generated if not specified

backend:
  type: "dlna"                  # dlna or local
  dlna:
    ip: "192.168.1.50"          # Required: DLNA device IP
    port: 1400                  # DLNA device port
    fixed_volume: false         # Ignore volume commands
    proxy_port: 7120            # Audio proxy port for DLNA streaming
    # description_url: ""       # UPnP description XML URL (auto-discovered via SSDP)
  # local:
  #   device: "default"         # Audio device name or "default"
  #   buffer_size: 2048         # Audio buffer size in frames

server:
  http_port: 8689               # mDNS discovery HTTP server
  bind_address: "0.0.0.0"       # Network interface to bind

logging:
  level: "info"                 # debug, info, warning, error

# --- Multi-Speaker Configuration ---
# Use 'speakers' instead of 'device'/'backend'/'server' for multiple speakers.
# Each speaker appears as a separate device in the Qobuz app.
# Ports are auto-assigned unless specified.
#
# speakers:
#   - name: "Living Room"
#     backend: dlna
#     dlna_ip: "192.168.1.50"
#     max_quality: auto
#     # http_port: 8689          # optional, auto-assigned
#     # proxy_port: 7120         # optional, auto-assigned
#
#   - name: "Office"
#     backend: dlna
#     dlna_ip: "192.168.1.51"
#     max_quality: 7
#
#   - name: "Headphones"
#     backend: local
#     audio_device: "Built-in Output"
